                <!-- ═══ EXTERNAL SERVICES (right column, x=1260) ═══ -->
                <!--
                  All three layers are 1180px wide (x=20..1200).
                  External nodes start at x=1260, leaving a clear 60px corridor
                  (x=1200..1260) used exclusively for routing backend→external edges.
                  No boxes exist in this corridor — zero crossings guaranteed.
                -->
                <mxCell id="ext-sf" value="Snowflake Cloud&#xa;(HTTPS / gosnowflake driver)" style="shape=mxgraph.azure.azure_function;fillColor=#fff9c4;strokeColor=#f0a500;fontStyle=1;fontSize=10;whiteSpace=wrap;" parent="1" vertex="1">
