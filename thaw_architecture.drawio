                <mxCell id="ext-sqlite" value="SQLite (local)&#xa;Function metadata cache&#xa;(fnmeta)" style="shape=mxgraph.cisco.storage.storage_server;fillColor=#f5f5f5;strokeColor=#666;fontStyle=1;fontSize=10;whiteSpace=wrap;" parent="1" vertex="1">
                    <mxGeometry x="1260" y="600" width="160" height="60" as="geometry"/>
                </mxCell>

                <!-- ═══════════════════════════════════════════════════════════════
                  CONNECTIONS
                  ═══════════════════════════════════════════════════════════════

                  VERTICAL FLOW (Frontend → Bridge → Backend)
                  ────────────────────────────────────────────
                  e1  layer-fe     → br-wailsjs   IPC call entry (straight down, left-aligned)
                  e2  br-wailsjs   → br-ipc        within bridge (horizontal)
                  e3  br-events    → layer-fe      Wails events back (dashed, straight up)
                  e4  br-ipc       → br-events     within bridge (horizontal)
                  e5  br-ipc       → layer-be      dispatch to Go packages (straight down)

                  BACKEND → EXTERNAL  (corridor routing, NO box crossings)
                  ─────────────────────────────────────────────────────────
                  All 5 edges exit the RIGHT boundary of layer-be (x=1200) at
                  staggered Y fractions and travel through the empty 60px corridor
                  (x=1200..1260) to reach external services.  Each edge uses a
                  distinct x-lane so they never overlap:

                    e6  exitY=0.20 → lane x=1207 → ext-sf     (abs exit y=520)
                    e7  exitY=0.35 → lane x=1214 → ext-ai     (abs exit y=557)
                    e8  exitY=0.55 → lane x=1221 → ext-git    (abs exit y=607)
                    e9  exitY=0.70 → lane x=1228 → ext-fs     (abs exit y=645)
                    e10 exitY=0.88 → lane x=1235 → ext-sqlite (abs exit y=690)

                  Exit-Y order == target-Y order (both ascending) so lines
                  cannot cross each other anywhere in the corridor.

                  External service center-left entry points (entryX=0, entryY=0.5):
                    ext-sf:     (1260, 95)    [y=60+70/2]
                    ext-ai:     (1260, 235)   [y=200+70/2]
                    ext-git:    (1260, 375)   [y=340+70/2]
                    ext-fs:     (1260, 515)   [y=480+70/2]
                    ext-sqlite: (1260, 630)   [y=600+60/2]
                ═══════════════════════════════════════════════════════════════ -->

                <!-- e1: Frontend layer → br-wailsjs (straight down, x aligned to br-wailsjs) -->
                <mxCell id="e1" value="IPC calls" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.1;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="layer-fe" target="br-wailsjs" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- e2: wailsjs → app.go (horizontal, within bridge) -->
                <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="layer-bridge" source="br-wailsjs" target="br-ipc" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- e3: Event bus → Frontend (dashed, exits top of br-events, enters bottom-right of layer-fe)
                     Both nodes are clear of x=770 in the inter-layer gap — no crossings. -->
                <mxCell id="e3" value="Wails events" style="edgeStyle=orthogonalEdgeStyle;rounded=0;dashed=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.68;entryY=1;entryDx=0;entryDy=0;" parent="1" source="br-events" target="layer-fe" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- e4: app.go → event bus (horizontal, within bridge) -->
                <mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="layer-bridge" source="br-ipc" target="br-events" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- e5: app.go → Backend layer (straight down through inter-layer gap) -->
                <mxCell id="e5" value="calls internal packages" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.38;entryY=0;entryDx=0;entryDy=0;" parent="1" source="br-ipc" target="layer-be" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>

                <!-- e6: Backend → Snowflake Cloud
                     Exit layer-be right edge at y=520, corridor lane x=1207, enter ext-sf at y=95 -->
                <mxCell id="e6" value="HTTPS/TLS · queries · DDL · fnmeta sync" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.2;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="layer-be" target="ext-sf" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1207" y="520"/>
                            <mxPoint x="1207" y="95"/>
                        </Array>
                    </mxGeometry>
                </mxCell>

                <!-- e7: Backend → AI APIs
                     Exit layer-be right edge at y=557, corridor lane x=1214, enter ext-ai at y=235 -->
                <mxCell id="e7" value="HTTPS REST + streaming" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.35;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="layer-be" target="ext-ai" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1214" y="557"/>
                            <mxPoint x="1214" y="235"/>
                        </Array>
                    </mxGeometry>
                </mxCell>

                <!-- e8: Backend → Git Remotes
                     Exit layer-be right edge at y=607, corridor lane x=1221, enter ext-git at y=375 -->
                <mxCell id="e8" value="HTTPS Git (OAuth)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.55;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="layer-be" target="ext-git" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1221" y="607"/>
                            <mxPoint x="1221" y="375"/>
                        </Array>
                    </mxGeometry>
                </mxCell>

                <!-- e9: Backend → Local Filesystem
                     Exit layer-be right edge at y=645, corridor lane x=1228, enter ext-fs at y=515
                     Covers: filesystem I/O, DDL exports, config reads, log rotation -->
                <mxCell id="e9" value="file I/O · DDL export · config · logs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="layer-be" target="ext-fs" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1228" y="645"/>
                            <mxPoint x="1228" y="515"/>
                        </Array>
                    </mxGeometry>
                </mxCell>

                <!-- e10: Backend → SQLite
                     Exit layer-be right edge at y=690, corridor lane x=1235, enter ext-sqlite at y=630 -->
                <mxCell id="e10" value="database/sql (fnmeta)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.88;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="layer-be" target="ext-sqlite" edge="1">
