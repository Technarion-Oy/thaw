# ── Logs (dev-mode log files; production logs go to OS-specific paths) ────────
logs/

# ── Go ────────────────────────────────────────────────────────────────────────
build/bin/
frontend/package.json.md5
temp.txt
*.exe
*.test
*.out
coverage.out
*.tmp          # atomic-write temp files produced by the DDL exporter

# ── Wails build artefacts ─────────────────────────────────────────────────────
/build/darwin/thaw.app
/build/windows/thaw.exe

# ── Frontend ──────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/*
!frontend/dist/.gitkeep

# ── Credentials / environment ─────────────────────────────────────────────────
.env
.env.*
!.env.example    # allow a committed example file

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE / tooling ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Generated documentation (source files in docs/ are tracked; output is not) ─
/docs/frontend/
/docs/backend/

# ── Claude Code (local session state — not project files) ─────────────────────
.claude/

# ── Release toolchain ─────────────────────────────────────────────────────────
node_modules/

# Vector DB
.chroma_db/
scripts/.venv/
